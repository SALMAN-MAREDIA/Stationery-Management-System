<%- include('partials/header') %>

  <!-- Page Banner -->
  <section class="page-banner">
    <div class="hero-overlay"></div>
    <div class="banner-content">
      <h1>About Us</h1>
      <p>Know more about Hotel Oasis</p>
    </div>
  </section>

  <!-- About Section -->
  <section class="section">
    <div class="container">
      <div class="about-content">
        <div class="about-text">
          <h2>Our Story</h2>
          <p>Hotel Oasis founded in 1985, ideally located in the heart of Mumbai City, commercial capital of India.</p>
          <p>You'll find everything more than your expectations. All rooms are well designed with vibrant colours and furniture. A perfect place for relaxation in luxury.</p>
          <p>Hotel Oasis has evolved from time to time in its effort to cater to the growing needs of global and domestic travellers whilst its best to keep the prices in an affordable range.</p>
        </div>
        <div class="about-image">
          <div class="about-placeholder">
            <i class="fas fa-hotel"></i>
            <span>Hotel Oasis<br>Since 1985</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <h2>Why Choose Us</h2>
      </div>
      <div class="about-features">
        <div class="about-feature">
          <div class="feature-icon"><i class="fas fa-bed"></i></div>
          <h3>32 Air-Conditioned Rooms</h3>
          <p>Hotel Oasis has 32 air-conditioned rooms with modern amenities like Free WiFi Internet, Colour TV with satellite channels and Intercom facility.</p>
        </div>
        <div class="about-feature">
          <div class="feature-icon"><i class="fas fa-clock"></i></div>
          <h3>Round the Clock Service</h3>
          <p>You'll find superb ambience with attentive, efficient and personalized services round the clock.</p>
        </div>
        <div class="about-feature">
          <div class="feature-icon"><i class="fas fa-location-dot"></i></div>
          <h3>Prime Location</h3>
          <p>Hotel Oasis is surrounded with city attractions like famous hospitals, business and tourist places.</p>
        </div>
        <div class="about-feature">
          <div class="feature-icon"><i class="fas fa-tags"></i></div>
          <h3>Affordable Prices</h3>
          <p>We strive to keep our prices in an affordable range while providing the best quality service and amenities.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2>Our Journey</h2>
      </div>
      <div class="timeline">
        <div class="timeline-item">
          <div class="timeline-dot"></div>
          <div class="timeline-content">
            <h3>1985</h3>
            <p>Hotel Oasis was founded in the heart of Mumbai City</p>
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-dot"></div>
          <div class="timeline-content">
            <h3>2000</h3>
            <p>Major renovation – upgraded to modern amenities and A/C rooms</p>
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-dot"></div>
          <div class="timeline-content">
            <h3>2015</h3>
            <p>Expanded to 32 rooms with free WiFi and satellite TV</p>
          </div>
        </div>
        <div class="timeline-item">
          <div class="timeline-dot"></div>
          <div class="timeline-content">
            <h3>Today</h3>
            <p>Continuing to serve global and domestic travellers with excellence</p>
          </div>
        </div>
      </div>
    </div>
  </section>

<%- include('partials/footer') %>
